<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>S&P 500 — Intrinsic Value vs Market Price</title>
<link rel="stylesheet" href="assets/dashboard.css" />
<script src="https://cdn.plot.ly/plotly-2.35.2.min.js" charset="utf-8"></script>
</head>
<body>
<header>
  <h1>S&amp;P 500 — IV vs Market Price</h1>
  <div class="meta">
    <span class="badge">{{ session_label }}</span>
    <span class="badge muted">Generated {{ generated_at_et }}</span>
    <span class="badge muted">Overlay {{ assumptions.version }}</span>
    {% if report and report.iv_coverage is defined %}
    <span class="badge cov">IV coverage {{ '%.0f'|format(report.iv_coverage*100) }}%</span>
    <span class="badge cov">Overlay coverage {{ '%.0f'|format(report.sector_coverage*100) }}%</span>
    {% endif %}
  </div>
  <p class="narrative">{{ assumptions.narrative }}</p>
</header>

{% if assumptions.macro %}
<section class="macro">
  <div class="macro-head">
    <h2>Macro lens — {{ assumptions.macro.as_of }}</h2>
    <p class="regime">{{ assumptions.macro.regime }}</p>
  </div>
  <div class="macro-grid">
    <div class="tile"><div class="lbl">Brent</div><div class="val">{{ assumptions.macro.brent_usd }}</div></div>
    <div class="tile"><div class="lbl">WTI</div><div class="val">{{ assumptions.macro.wti_usd }}</div></div>
    <div class="tile"><div class="lbl">Fed funds</div><div class="val">{{ assumptions.macro.fed_funds_pct }}</div></div>
    <div class="tile"><div class="lbl">10-yr UST</div><div class="val">{{ assumptions.macro.ten_yr_treasury_pct }}</div></div>
    <div class="tile"><div class="lbl">PCE YoY</div><div class="val">{{ assumptions.macro.pce_yoy_pct }}</div></div>
    <div class="tile"><div class="lbl">ISM prices</div><div class="val">{{ assumptions.macro.ism_prices_idx }}</div></div>
    <div class="tile"><div class="lbl">S&amp;P 500</div><div class="val">{{ assumptions.macro.sp500_level }}</div></div>
    <div class="tile"><div class="lbl">Fwd P/E</div><div class="val">{{ assumptions.macro.sp500_fwd_pe }}x</div></div>
    <div class="tile"><div class="lbl">Recession (WSJ)</div><div class="val">{{ assumptions.macro.recession_prob_wsj_pct }}%</div></div>
    <div class="tile"><div class="lbl">BRK cash</div><div class="val">${{ assumptions.macro.brk_cash_b }}B</div></div>
  </div>
  <p class="geopolitics">{{ assumptions.macro.geopolitics }}</p>
</section>
{% endif %}

{% set g = assumptions.slider_guidance or {} %}
{% macro slider_help(key) %}{% set s = g[key] %}{% if s %}{{ s.what }}&#10;&#10;Raise when: {{ s.raise_when }}&#10;Lower when: {{ s.lower_when }}{% endif %}{% endmacro %}

<section class="viz portfolio" id="portfolio-section" style="display:none;">
  <h2>📁 My Portfolio — intrinsic value vs market price</h2>
  <p class="muted">Each holding valued by a <b>world-class, data-driven Buffett-conservative DCF</b> (v2): discount rate from the live US Treasury curve (~15-yr risk-free {{ '%.2f'|format(assumptions.macro_curve.risk_free_15y_pct) if assumptions.macro_curve else '4.65' }}%) + beta + sector, 9% floor; FCF-margin-normalized owner earnings; sector + last-earnings-driven 3-phase growth; buyback yield from history + announced authorizations. <b>Disc</b> = discount rate; <b>Sheet</b> = your original Google-Sheet IV for comparison. Hover a row for the model's latest-earnings note &amp; assumptions. <b>Upside %</b> = (IV − price)/price. Model IVs are fixed (fundamentals don't move with the macro sliders).</p>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Ticker</th><th>Holding</th><th>Model</th>
          <th class="num">Disc</th><th class="num">Price</th><th class="num">IV / share</th>
          <th class="num">Sheet</th><th class="num">Upside %</th><th>Verdict</th>
        </tr>
      </thead>
      <tbody id="portfolio-body"></tbody>
    </table>
  </div>
</section>

<section class="controls">
  <div class="control">
    <label title="{{ slider_help('discount_premium') }}">Base discount-rate premium
      <span class="val" id="val-dr-prem"></span></label>
    <input id="slider-dr-prem" type="range" min="-2" max="6" step="0.05"
           title="{{ slider_help('discount_premium') }}" />
    <small>default {{ '%.1f'|format(assumptions.base.discount_premium*100) }}%</small>
    {% if g.discount_premium %}<small class="lyn">📊 {{ g.discount_premium.today }}</small>{% endif %}
  </div>
  <div class="control">
    <label title="{{ slider_help('growth_haircut') }}">Base growth haircut
      <span class="val" id="val-g-hair"></span></label>
    <input id="slider-g-hair" type="range" min="-5" max="3" step="0.05"
           title="{{ slider_help('growth_haircut') }}" />
    <small>default {{ '%.1f'|format(assumptions.base.growth_haircut*100) }}%</small>
    {% if g.growth_haircut %}<small class="lyn">📊 {{ g.growth_haircut.today }}</small>{% endif %}
  </div>
  <div class="control">
    <label title="{{ slider_help('mos_add') }}">Base margin-of-safety add
      <span class="val" id="val-mos"></span></label>
    <input id="slider-mos" type="range" min="-3" max="15" step="0.1"
           title="{{ slider_help('mos_add') }}" />
    <small>default {{ '%.1f'|format(assumptions.base.mos_add*100) }}%</small>
    {% if g.mos_add %}<small class="lyn">📊 {{ g.mos_add.today }}</small>{% endif %}
  </div>
  <div class="control">
    <label title="{{ slider_help('global_growth_shift') }}">Global growth shift (all tickers)
      <span class="val" id="val-global-g"></span></label>
    <input id="slider-global-g" type="range" min="-5" max="5" step="0.1" value="0"
           title="{{ slider_help('global_growth_shift') }}" />
    <small>±5% bias on revenue growth before DCF</small>
    {% if g.global_growth_shift %}<small class="lyn">📊 {{ g.global_growth_shift.today }}</small>{% endif %}
  </div>
  <button id="btn-reset">Reset to base case</button>
</section>

<section class="filters">
  <label>Sector
    <select id="filter-sector"><option value="All">All</option></select>
  </label>
  <label><input id="filter-brk" type="checkbox" /> BRK-held only</label>
  <label>Search
    <input id="filter-search" type="search" placeholder="ticker or company" />
  </label>
  <label>Min discount %
    <input id="filter-min-disc" type="number" step="5" placeholder="-100" />
  </label>
  <span id="row-count" class="muted"></span>
</section>

<section class="viz">
  <h2>Discount vs market cap</h2>
  <div id="scatter" style="height:520px;"></div>
</section>

<section class="viz">
  <h2>Companies (sorted by discount, highest first)</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Ticker</th><th>Company</th><th>Sector</th><th>Val</th>
          <th class="num">Price</th><th class="num">MCap $B</th>
          <th class="num">IV $B</th><th class="num">Discount %</th>
          <th>BRK?</th><th class="num">BRK $B</th>
        </tr>
      </thead>
      <tbody id="table-body"></tbody>
    </table>
  </div>
</section>

<section class="viz">
  <h2>Discount over time</h2>
  <div class="history-controls">
    <label>Tickers (comma-separated)
      <input id="history-tickers" type="text" placeholder="AAPL, BRK-B, OXY" />
    </label>
    <button id="btn-history">Plot</button>
    <span id="history-status" class="muted"></span>
  </div>
  <div id="history" style="height:380px;"></div>
</section>

<details class="advanced">
  <summary>Advanced: DCF base inputs &amp; sector overlay matrix</summary>

  <h3>DCF base inputs</h3>
  <table class="inputs">
    <thead><tr><th>Input</th><th class="num">Value</th><th>What it is &amp; when to change it</th></tr></thead>
    <tbody>
      <tr><td>Discount rate (cost of equity)</td><td class="num">{{ '%.1f'|format(assumptions.base.discount_rate*100) }}%</td><td>{{ assumptions.dcf_input_notes.discount_rate if assumptions.dcf_input_notes }}</td></tr>
      <tr><td>Terminal growth</td><td class="num">{{ '%.1f'|format(assumptions.base.terminal_growth*100) }}%</td><td>{{ assumptions.dcf_input_notes.terminal_growth if assumptions.dcf_input_notes }}</td></tr>
      <tr><td>Projection horizon</td><td class="num">{{ assumptions.base.projection_years }} yr</td><td>{{ assumptions.dcf_input_notes.projection_years if assumptions.dcf_input_notes }}</td></tr>
      <tr><td>Margin of safety (base)</td><td class="num">{{ '%.0f'|format(assumptions.base.margin_of_safety*100) }}%</td><td>{{ assumptions.dcf_input_notes.margin_of_safety if assumptions.dcf_input_notes }}</td></tr>
    </tbody>
  </table>

  <h3>Geopolitical overlay — current base layer (before sector deltas)</h3>
  <table class="inputs">
    <thead><tr><th>Slider</th><th class="num">Default</th><th>What it does &amp; today's read</th></tr></thead>
    <tbody>
      {% for key, label in [
        ('discount_premium','Discount-rate premium'),
        ('growth_haircut','Growth haircut'),
        ('mos_add','MOS add'),
        ('global_growth_shift','Global growth shift'),
      ] %}
        {% set s = (assumptions.slider_guidance or {}).get(key) %}
        {% if s %}
        <tr>
          <td>{{ label }}</td>
          <td class="num">
            {% if key == 'discount_premium' %}{{ '%+.2f'|format(assumptions.base.discount_premium*100) }}%
            {% elif key == 'growth_haircut' %}{{ '%+.2f'|format(assumptions.base.growth_haircut*100) }}%
            {% elif key == 'mos_add' %}{{ '%+.2f'|format(assumptions.base.mos_add*100) }}%
            {% else %}0.00%
            {% endif %}
          </td>
          <td><strong>What:</strong> {{ s.what }}<br/><strong>Raise when:</strong> {{ s.raise_when }}<br/><strong>Lower when:</strong> {{ s.lower_when }}<br/><strong>Today:</strong> {{ s.today }}</td>
        </tr>
        {% endif %}
      {% endfor %}
    </tbody>
  </table>

  <h3>Sector overlay matrix (added on top of base)</h3>
  <p class="muted">Each row shows the deltas applied to base discount premium / growth haircut / MOS for that sector. Negative discount premium = sector tailwind. Positive growth haircut = upward bias to growth. Negative MOS = less conservative.</p>
  <table class="inputs sectors">
    <thead><tr><th>Sector keyword</th><th class="num">Δ Discount premium</th><th class="num">Δ Growth haircut</th><th class="num">Δ MOS add</th></tr></thead>
    <tbody>
      {% for sec, vals in assumptions.sectors.items() %}
      <tr>
        <td>{{ sec }}</td>
        <td class="num {{ 'neg' if vals[0]<0 else ('pos' if vals[0]>0 else '') }}">{{ '%+.2f'|format(vals[0]*100) }}%</td>
        <td class="num {{ 'pos' if vals[1]>0 else ('neg' if vals[1]<0 else '') }}">{{ '%+.2f'|format(vals[1]*100) }}%</td>
        <td class="num {{ 'neg' if vals[2]<0 else ('pos' if vals[2]>0 else '') }}">{{ '%+.2f'|format(vals[2]*100) }}%</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</details>

<footer>
  <p>
    Source: <a href="https://github.com/Semenka/SP500">github.com/Semenka/SP500</a> ·
    Geopolitical overlay {{ assumptions.version }} ·
    DCF: 15-yr owner-earnings + liquid assets, base discount {{ '%.1f'|format(assumptions.base.discount_rate*100) }}%, terminal {{ '%.1f'|format(assumptions.base.terminal_growth*100) }}%, MOS {{ '%.0f'|format(assumptions.base.margin_of_safety*100) }}%.
  </p>
</footer>

<script>
window.SP500_LATEST = {{ latest_json|safe }};
window.SP500_ASSUMPTIONS = {{ assumptions_json|safe }};
</script>
<script src="assets/dashboard.js"></script>
</body>
</html>
